# Email Configuration
# Replace with your actual Gmail credentials
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password

# OpenAI API Configuration
# Replace with your actual OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# Instructions:
# 1. Replace your-gmail@gmail.com with your actual Gmail
# 2. Replace your-app-password with your Gmail App Password
# 3. Get App Password: https://myaccount.google.com/apppasswords
# 4. Replace your-openai-api-key-here with your OpenAI API key
# 5. Get OpenAI API key: https://platform.openai.com/api-keys
# 6. Restart server: npm run server
